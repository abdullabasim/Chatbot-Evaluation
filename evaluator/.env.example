
# Evaluator Defaults (can be overridden via CLI flags)


# Target API
EVAL_BASE_URL=http://localhost:8080

# Dataset and output
EVAL_DATASET_PATH=test_cases.json
EVAL_OUTPUT_PATH=report.json

# Evaluation strategy
EVAL_RUNS=3
EVAL_SEMANTIC_THRESHOLD=0.45

# PERCENTAGE (0.0 - 1.0) of keywords from the dataset that must be 
# matched (via exact lemma or semantic similarity) for the turn to pass.
# For example, 0.50 means the chatbot must cover at least 50% of the required keywords.
EVAL_COVERAGE_THRESHOLD=0.50

# Sentence-transformer model
EVAL_MODEL_NAME=all-MiniLM-L6-v2
EVAL_FORCE_ONNX_EXPORT=False

# Language support
EVAL_LANGUAGE=en

# Concurrency and networking
EVAL_MAX_CONCURRENCY=20
EVAL_REQUEST_TIMEOUT=10.0
EVAL_MAX_RETRIES=3

# Logging level
EVAL_LOG_LEVEL=WARNING
