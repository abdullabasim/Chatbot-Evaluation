
# Mock API Configuration


# Host and port for the mock chatbot API server
MOCK_API_HOST=0.0.0.0
MOCK_API_PORT=8080
MOCK_WORKERS=1

# LLM Simulation
# Probability (0.0 – 1.0) of returning a hallucinated/wrong response
MOCK_HALLUCINATION_RATE=0.05

# Simulated LLM latency range in milliseconds
MOCK_MIN_LATENCY_MS=200
MOCK_MAX_LATENCY_MS=800

# Confidence score ranges
MOCK_CONFIDENCE_MIN=0.72
MOCK_CONFIDENCE_MAX=0.99
MOCK_HALLUCINATION_CONFIDENCE_MIN=0.10
MOCK_HALLUCINATION_CONFIDENCE_MAX=0.45
